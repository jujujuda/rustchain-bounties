{
  "name": "rustchain-dashboard",
  "displayName": "RustChain Dashboard",
  "description": "VS Code extension for RustChain wallet balance, miner status, and bounty board",
  "version": "1.0.0",
  "publisher": "jujujuda",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Other", "Developer Tools"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "RustChain",
      "properties": {
        "rustchain.walletName": {
          "type": "string",
          "default": "",
          "description": "Your RustChain wallet name (miner_id)"
        },
        "rustchain.nodeUrl": {
          "type": "string",
          "default": "https://50.28.86.131",
          "description": "RustChain node URL"
        },
        "rustchain.refreshInterval": {
          "type": "number",
          "default": 60,
          "description": "Refresh interval in seconds"
        }
      }
    },
    "commands": [
      {
        "command": "rustchain.refresh",
        "title": "Refresh RustChain Data"
      },
      {
        "command": "rustchain.openBounty",
        "title": "Open Bounty in Browser"
      },
      {
        "command": "rustchain.openWallet",
        "title": "Open Wallet in Explorer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rustchain.refresh",
          "when": "view == rustchain.bounties",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --yarn"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  }
}
